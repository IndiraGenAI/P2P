{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@assets/*": [
              "src/assets/*"
            ],
            "@components/*": [
              "src/components/*"
            ],
            "@lib/*": [
              "src/lib/*"
            ],
            "@pages/*": [
              "src/pages/*"
            ],
            "@services/*": [
              "src/services/*"
            ],
            "@state/*": [
              "src/state/*"
            ],
            "@styles/*": [
              "src/styles/*"
            ],
            "@utils/*": [
              "src/utils/*"
            ],
          }
    }
}