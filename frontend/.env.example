# ----------------------------------------------------------------------------
# P2P-ORG  ·  Frontend (Vite + React)  ·  Environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to client code.
# NEVER put secrets here — anything in this file is shipped to the browser.
# ----------------------------------------------------------------------------

# --- API ---------------------------------------------------------------------
# Base URL the frontend uses to talk to the backend.
# Must match backend's PORT + PREFIX (see backend/back-service/.env).
VITE_API_BASE_URL=http://localhost:3010/api

# Request timeout in milliseconds for HTTP calls
VITE_API_TIMEOUT=30000

# --- App identity ------------------------------------------------------------
VITE_APP_NAME=P2P-ORG
VITE_APP_TAGLINE=Procure-to-Pay

# --- Feature flags -----------------------------------------------------------
# "true" | "false"
VITE_ENABLE_DEVTOOLS=true
